# Environment variables for Market Signal Lab
# Copy this file to .env.openclaw and fill in secrets.
# IMPORTANT: Do NOT commit .env.openclaw (it contains secrets).

# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=stock_analysis

# --- Redis (optional; set REDIS_PASS if needed) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30
REDIS_MAX_CONNECTIONS=20
REDIS_MAX_VALUE_BYTES=5000000
REDIS_BATCH_HISTORY_CACHE_CHUNK_SIZE=200

# --- Email (optional; disabled until EMAIL_ENABLED=1) ---
EMAIL_ENABLED=0
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
EMAIL_USER=your-email@example.com
EMAIL_PWD=
EMAIL_TO=your-email@example.com

# --- Logging ---
# Date-stamped logs are written to logs/stock_analyzer-YYYYMMDD.log.
# Old date-stamped logs are removed on startup after this many days.
LOG_RETENTION_DAYS=5
# 1 = write every email subject/body/result to the daily log so reports can be audited later.
LOG_EMAIL_CONTENT=1

# --- Tushare (optional; leave empty if not used) ---
TUSHARE_TOKEN=
TUSHARE_URL=https://api.tushare.pro
# Conservative request pacing for production jobs running together.
TUSHARE_MIN_REQUEST_INTERVAL_SEC=0.12
TUSHARE_BATCH_HISTORY_SIZE=50
TUSHARE_BATCH_HISTORY_SLEEP_SEC=0.15
# Official Tushare auction endpoint. Keep disabled unless the token has
# stk_auction permission; the auction strategy will use rt_k fallback.
TUSHARE_STK_AUCTION_ENABLED=0
# rt_k is realtime daily aggregation and is preferred for strategies that need
# current price/high/low/full-day volume/amount. rt_min is minute-level fallback.
TUSHARE_REALTIME_PRIMARY=rt_k
# Extra guard: rt_k will be ignored unless this is set to 1.
TUSHARE_RT_K_ENABLED=1
TUSHARE_REALTIME_CHUNK_SIZE=200
TUSHARE_REALTIME_SLEEP_SEC=0.08
TUSHARE_RT_MIN_CHUNK_SIZE=200
TUSHARE_RT_MIN_SLEEP_SEC=0.08
TUSHARE_RT_MIN_SINGLE_MAX_PER_RUN=10
# Same-day individual fund flow with a legacy endpoint fallback.
TUSHARE_MONEYFLOW_PRIMARY=moneyflow_dc
TUSHARE_MONEYFLOW_FALLBACK=moneyflow

# --- Tencent/GTimg minute fallback (optional; used when tushare 1min is rate-limited) ---
# 1 = enable fallback (default). 0 = disable fallback.
TENCENT_MINUTE_FALLBACK_ENABLED=1
# Base URL and path for mkline endpoint
TENCENT_MINUTE_FALLBACK_BASE_URL=http://ifzq.gtimg.cn
TENCENT_MINUTE_FALLBACK_MKLINE_PATH=/appstock/app/kline/mkline
# How many 1-min points to request (default 500)
TENCENT_MINUTE_FALLBACK_COUNT=500
# Request timeout in seconds (default 5)
TENCENT_MINUTE_FALLBACK_TIMEOUT_SEC=5
# Optional request headers
# TENCENT_MINUTE_FALLBACK_USER_AGENT=Mozilla/5.0
# TENCENT_MINUTE_FALLBACK_HEADERS_JSON={"User-Agent":"Mozilla/5.0","Referer":"https://quote.eastmoney.com"}
# Optional retries (defaults to single attempt)
TENCENT_MINUTE_FALLBACK_RETRIES=0
TENCENT_MINUTE_FALLBACK_RETRY_DELAY_SEC=0
